# Copy this file to .env and fill in your GitHub token.
#   cp .env.example .env
#
# Create a token at https://github.com/settings/tokens
# A fine-grained or classic token with default (public) read access is enough —
# no special scopes are required for the public Search API. The token mainly
# raises your rate limit (30 search req/min authenticated vs. 10/min anonymous).
GITHUB_TOKEN=paste_your_token_here
